---
import { getLangFromUrl, getTranslations } from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const t = getTranslations(lang)
---

<footer class="relative z-10 w-full border-t border-white/5 pt-16 pb-12">
	<div class="mx-auto max-w-7xl px-6">
		<div class="flex flex-col items-center gap-8 md:flex-row md:justify-between">
			<p class="font-body text-sm text-[#6b6055]">
				© {new Date().getFullYear()} Cristhofer Pincetti. <span data-i18n="footer.tagline">{t("footer.tagline")}</span>
			</p>
			<div class="flex items-center gap-8">
				<a
					class="font-mono text-xs tracking-[0.2em] text-[#a89a84] uppercase transition-colors hover:text-[#f0e6d2]"
					href="https://github.com/BrainerVirus"
					target="_blank"
					rel="noopener noreferrer"
				>
					GitHub
				</a>
				<a
					class="font-mono text-xs tracking-[0.2em] text-[#a89a84] uppercase transition-colors hover:text-[#f0e6d2]"
					href="https://linkedin.com/in/cristhofer-pincetti"
					target="_blank"
					rel="noopener noreferrer"
				>
					LinkedIn
				</a>
			</div>
			<button
				id="back-to-top"
				class="flex cursor-pointer items-center gap-2 font-mono text-xs text-[#6b6055] uppercase transition-colors hover:text-[#f0e6d2]"
				data-i18n-aria-label="footer.backToTop"
				aria-label={t("footer.backToTop")}
			>
				<span data-i18n="footer.backToTop">{t("footer.backToTop")}</span>
				<span class="material-symbols-outlined text-sm">north</span>
			</button>
		</div>
	</div>
</footer>

<script>
	function initBackToTop() {
		const btn = document.getElementById("back-to-top")
		if (!btn) return
		btn.addEventListener("click", () => {
			window.scrollTo({ top: 0, behavior: "smooth" })
		})
	}

	initBackToTop()
	document.addEventListener("astro:after-swap", () => {
		initBackToTop()
	})
</script>
