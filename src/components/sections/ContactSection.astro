---
import { getLangFromUrl, getTranslations, getTranslation } from "@/i18n/utils"
import ContactForm from "@/components/react/ContactForm"

const lang = getLangFromUrl(Astro.url)
const t = getTranslations(lang)
const locale = lang as "en" | "es"

const translations = {
	name: t("contact.form.name"),
	namePlaceholder: t("contact.form.namePlaceholder"),
	email: t("contact.form.email"),
	emailPlaceholder: t("contact.form.emailPlaceholder"),
	message: t("contact.form.message"),
	messagePlaceholder: t("contact.form.messagePlaceholder"),
	submit: t("contact.form.submit"),
	sending: t("contact.messages.transmitting"),
	error: {
		nameRequired: getTranslation(locale, "contact.error.nameRequired"),
		emailRequired: getTranslation(locale, "contact.error.emailRequired"),
		emailInvalid: getTranslation(locale, "contact.error.emailInvalid"),
		messageRequired: getTranslation(locale, "contact.error.messageRequired"),
		messageMinLength: getTranslation(locale, "contact.error.messageMinLength"),
	},
	success: getTranslation(locale, "contact.messages.success"),
	failed: getTranslation(locale, "contact.messages.failed"),
	connectionLost: getTranslation(locale, "contact.messages.connectionLost"),
}
---

<section
	class="relative flex min-h-screen w-full scroll-mt-24 items-center overflow-hidden py-24"
	id="contact"
>
	<div class="relative mx-auto w-full max-w-7xl px-6">
		<div class="grid grid-cols-1 items-start gap-16 lg:grid-cols-[0.82fr_1.18fr] lg:gap-16">
			<!-- Left -->
			<div class="contact-left flex flex-col justify-center">
				<h2
					class="text-4xl font-light text-[#f0e6d2] md:text-5xl"
					style="line-height: 1.1; letter-spacing: -0.04em;"
					data-i18n="contact.title"
				>
					{t("contact.title")}
				</h2>
				<p class="mt-4 text-lg text-[#a89a84]" data-i18n="contact.subtitle">
					{t("contact.subtitle")}
				</p>

				<div class="mt-10 flex items-center gap-6">
					<a
						href="https://github.com/BrainerVirus"
						target="_blank"
						rel="noopener noreferrer"
						class="group relative flex items-center gap-2 font-mono text-xs tracking-[0.15em] uppercase text-[#6b6055]"
					>
						<svg
							class="h-4 w-4 fill-current transition-colors group-hover:text-[#f0e6d2]"
							viewBox="0 0 24 24"
						>
							<path
								d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
							></path>
						</svg>
						<span class="transition-colors group-hover:text-[#f0e6d2]">
							GitHub
						</span>
						<span class="absolute -bottom-1 left-0 h-px w-0 bg-[#f0e6d2] transition-all duration-300 group-hover:w-full"></span>
					</a>
					<a
						href="https://linkedin.com/in/cristhofer-pincetti"
						target="_blank"
						rel="noopener noreferrer"
						class="group relative flex items-center gap-2 font-mono text-xs tracking-[0.15em] uppercase text-[#6b6055]"
					>
						<svg
							class="h-4 w-4 fill-current transition-colors group-hover:text-[#f0e6d2]"
							viewBox="0 0 24 24"
						>
							<path
								d="M19 0h-14c-2.761 0-5 2.239-5 5v14c0 2.761 2.239 5 5 5h14c2.762 0 5-2.239 5-5v-14c0-2.761-2.238-5-5-5zm-11 19h-3v-11h3v11zm-1.5-12.268c-.966 0-1.75-.79-1.75-1.764s.784-1.764 1.75-1.764 1.75.79 1.75 1.764-.783 1.764-1.75 1.764zm13.5 12.268h-3v-5.604c0-3.368-4-3.113-4 0v5.604h-3v-11h3v1.765c1.396-2.586 7-2.777 7 2.476v6.759z"
							></path>
						</svg>
						<span class="transition-colors group-hover:text-[#f0e6d2]">
							LinkedIn
						</span>
						<span class="absolute -bottom-1 left-0 h-px w-0 bg-[#f0e6d2] transition-all duration-300 group-hover:w-full"></span>
					</a>
				</div>
			</div>

			<!-- Right -->
			<div class="contact-right relative flex items-center justify-stretch">
				<div
					class="gradient-blob absolute -inset-24 -z-10"
					style="background: radial-gradient(ellipse at 50% 50%, rgba(58, 122, 77, 0.18), transparent 74%); filter: blur(70px);"
				></div>
				<div class="relative w-full max-w-3xl">
					<ContactForm
						locale={locale}
						translations={translations}
						client:load
					/>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	import gsap from "gsap"
	import ScrollTrigger from "gsap/ScrollTrigger"

	gsap.registerPlugin(ScrollTrigger)

	let contactCtx: gsap.Context | null = null

	function initContactAnimations() {
		if (contactCtx) {
			contactCtx.revert()
		}

		contactCtx = gsap.context(() => {
			const section = document.querySelector("#contact")
			if (!section) return

			const left = section.querySelector(".contact-left")
			const right = section.querySelector(".contact-right")
			const blob = section.querySelector(".gradient-blob")

			if (left) {
				gsap.fromTo(
					left,
					{ opacity: 0, x: -40 },
					{
						opacity: 1,
						x: 0,
						duration: 0.8,
						ease: "power3.out",
						scrollTrigger: {
							trigger: section,
							start: "top 80%",
							toggleActions: "play none none none",
						},
					}
				)
			}

			if (right) {
				gsap.fromTo(
					right,
					{ opacity: 0, x: 40 },
					{
						opacity: 1,
						x: 0,
						duration: 0.8,
						ease: "power3.out",
						delay: 0.2,
						scrollTrigger: {
							trigger: section,
							start: "top 80%",
							toggleActions: "play none none none",
						},
					}
				)
			}

			if (blob) {
				gsap.fromTo(
					blob,
					{ y: 0 },
					{
						y: -80,
						ease: "none",
						scrollTrigger: {
							trigger: section,
							start: "top bottom",
							end: "bottom top",
							scrub: true,
						},
					}
				)
			}
		}, "#contact")
	}

	initContactAnimations()
	document.addEventListener("astro:after-swap", () => {
		initContactAnimations()
	})
</script>
