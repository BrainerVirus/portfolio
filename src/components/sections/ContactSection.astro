---
import { getLangFromUrl, getTranslations, getTranslation } from "@/i18n/utils"
import ContactForm from "@/components/react/ContactForm"

const lang = getLangFromUrl(Astro.url)
const t = getTranslations(lang)
const locale = lang as "en" | "es"

const translations = {
	senderId: t("contact.form.senderId"),
	senderIdPlaceholder: t("contact.form.senderIdPlaceholder"),
	frequency: t("contact.form.frequency"),
	frequencyPlaceholder: t("contact.form.frequencyPlaceholder"),
	transmission: t("contact.form.transmission"),
	transmissionPlaceholder: t("contact.form.transmissionPlaceholder"),
	submit: t("contact.form.submit"),
	sending: t("contact.messages.transmitting"),
	sent: t("contact.messages.transmitted"),
	error: {
		nameRequired: getTranslation(locale, "contact.error.nameRequired"),
		emailRequired: getTranslation(locale, "contact.error.emailRequired"),
		emailInvalid: getTranslation(locale, "contact.error.emailInvalid"),
		messageRequired: getTranslation(locale, "contact.error.messageRequired"),
		messageMinLength: getTranslation(locale, "contact.error.messageMinLength"),
	},
	success: getTranslation(locale, "contact.messages.success"),
	failed: getTranslation(locale, "contact.messages.failed"),
	connectionLost: getTranslation(locale, "contact.messages.connectionLost"),
}
---

<section class="relative w-full scroll-mt-24 overflow-hidden pt-32 pb-48" id="contact">
	<div class="bg-nebula-dense absolute inset-0 -z-10 opacity-40 blur-[120px]"></div>
	<div class="relative mx-auto max-w-7xl px-6">
		<div class="mb-20 flex flex-col items-center text-center">
			<div
				class="animate-float border-primary/30 bg-primary/10 mb-4 inline-flex items-center justify-center rounded-full border p-3"
			>
				<span class="material-symbols-outlined text-primary">sensors</span>
			</div>
			<h2
				class="bg-linear-to-r from-white to-gray-400 bg-clip-text pb-2 text-4xl font-bold text-transparent md:text-5xl"
			>
				{t("contact.title")}
			</h2>
			<p class="mt-2 max-w-lg text-gray-400">
				{t("contact.subtitle")}
			</p>
		</div>
		<div class="grid grid-cols-1 items-center gap-16 lg:grid-cols-2 lg:gap-24">
			<div class="order-2 lg:order-1">
				<ContactForm locale={locale} translations={translations} client:load />
			</div>
			<div class="order-1 flex flex-col items-center justify-center lg:order-2">
				<div class="relative flex aspect-square w-full max-w-100 items-center justify-center">
					<div class="comm-beam absolute bottom-1/4 left-1/4 h-80 animate-pulse opacity-40"></div>
					<div class="comm-beam animate-pulse-glow absolute bottom-1/4 left-1/2 h-125 opacity-30">
					</div>
					<div
						class="comm-beam absolute right-1/4 bottom-1/4 h-80 animate-pulse opacity-40"
						style="animation-delay: 1s"
					>
					</div>
					<div class="animate-float absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2">
						<div class="holo-glow scale-[1.5] opacity-80">
							<span
								class="material-symbols-outlined text-primary cursor-default text-[140px] select-none"
								>local_cafe</span
							>
						</div>
						<div
							class="animate-orbit border-primary/20 absolute top-1/2 left-1/2 h-56 w-56 -translate-x-1/2 -translate-y-1/2 rounded-full border opacity-50"
						>
						</div>
						<div
							class="animate-orbit-reverse border-primary/40 absolute top-1/2 left-1/2 h-40 w-40 -translate-x-1/2 -translate-y-1/2 rounded-full border opacity-30"
						>
						</div>
					</div>
					<div
						class="to-background-dark absolute bottom-0 left-1/2 h-20 w-85 -translate-x-1/2 rounded-t-[40px] border-x border-t border-white/10 bg-linear-to-b from-[#2a2430] shadow-[0_-15px_40px_rgba(131,59,145,0.3)]"
						style="perspective: 800px"
					>
						<div
							class="relative flex h-full w-full items-center justify-around overflow-hidden rounded-t-[40px] bg-[#1a1620] px-12"
						>
							<div
								class="h-3 w-3 animate-pulse rounded-full bg-green-500/60 shadow-[0_0_8px_rgba(34,197,94,0.5)]"
							>
							</div>
							<div class="flex w-20 flex-col gap-1">
								<div class="h-1 w-full rounded-full bg-white/20"></div>
								<div class="bg-primary/40 h-1 w-2/3 rounded-full"></div>
								<div class="h-1 w-full rounded-full bg-white/10"></div>
							</div>
							<div class="bg-primary/60 h-3 w-3 rounded-full"></div>
							<div
								class="pointer-events-none absolute inset-0 bg-linear-to-r from-transparent via-white/5 to-transparent"
							>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</div>
</section>

<script>
	import gsap from "gsap"
	import { ScrollTrigger } from "gsap/ScrollTrigger"
	import { staggerFadeIn } from "@/lib/animations"

	gsap.registerPlugin(ScrollTrigger)

	function initContactAnimations() {
		// Kill existing ScrollTriggers to prevent accumulation
		ScrollTrigger.killAll()

		// Section heading fade-in
		const heading = document.querySelector("#contact .mb-20")
		if (heading) {
			staggerFadeIn(heading, "> *", 0.15)
		}

		// Form card slide-in from left
		const formCard = document.querySelector("#contact-form")
		if (formCard) {
			gsap.fromTo(
				formCard,
				{ opacity: 0, x: -40 },
				{
					opacity: 1,
					x: 0,
					duration: 0.8,
					ease: "power3.out",
					scrollTrigger: {
						trigger: "#contact-form",
						start: "top 80%",
						toggleActions: "play none none none",
					},
				}
			)
		}

		// Visual elements stagger in
		const visualEls = document.querySelectorAll(
			"#contact .comm-beam, #contact .holo-glow, #contact .orbit-ring, #contact .rounded-t-\\[40px\\]"
		)
		gsap.fromTo(
			visualEls,
			{ opacity: 0, y: 20 },
			{
				opacity: 1,
				y: 0,
				duration: 0.6,
				stagger: 0.1,
				ease: "power2.out",
				scrollTrigger: {
					trigger: "#contact .grid",
					start: "top 80%",
					toggleActions: "play none none none",
				},
			}
		)
	}

	initContactAnimations()
	document.addEventListener("astro:after-swap", () => {
		setTimeout(initContactAnimations, 100)
	})
</script>
