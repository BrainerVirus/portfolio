---
import SkillsBento from "./SkillsBento.astro"
import SkillsOrbital from "./SkillsOrbital.astro"

export type SkillsSectionVariant = "orbital" | "bento"

export interface Props {
	/** Defaults to `"orbital"` when omitted. */
	variant?: SkillsSectionVariant
}

// "bento" = masonry grid with 3D flip entrance (recommended)
// "orbital" = concentric rings with rotating constellation
const { variant = "orbital" } = Astro.props
---

{variant === "bento" ? <SkillsBento /> : <SkillsOrbital />}
