---
import { getLangFromUrl, getTranslations } from "@/i18n/utils"
const lang = getLangFromUrl(Astro.url)
const t = getTranslations(lang)
---

<section class="relative flex min-h-screen items-center justify-center overflow-hidden bg-[#0a0e0a]" id="about">
	<div class="bg-forest-whisper absolute inset-0 -z-10"></div>

	<div class="about-decor pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
		<svg class="about-circle-main absolute h-72 w-72 opacity-15" style="top: 18%; right: 5%;" viewBox="0 0 100 100" fill="none">
			<circle cx="50" cy="50" r="48" stroke="#3a7a4d" stroke-width="0.5"></circle>
			<circle cx="50" cy="50" r="38" stroke="#3a7a4d" stroke-width="0.3" stroke-dasharray="4 6"></circle>
			<circle cx="50" cy="50" r="28" stroke="#4a9a6d" stroke-width="0.4"></circle>
		</svg>
		<svg class="about-circle-cross absolute h-48 w-48 opacity-10" style="top: 65%; left: 8%;" viewBox="0 0 100 100" fill="none">
			<circle cx="50" cy="50" r="48" stroke="#f0e6d2" stroke-width="0.3"></circle>
			<line x1="50" y1="5" x2="50" y2="95" stroke="#f0e6d2" stroke-width="0.3"></line>
			<line x1="5" y1="50" x2="95" y2="50" stroke="#f0e6d2" stroke-width="0.3"></line>
			<circle cx="50" cy="50" r="4" fill="#f0e6d2" opacity="0.6"></circle>
		</svg>
		<svg class="about-circle-accent absolute h-32 w-32 opacity-12" style="bottom: 22%; right: 30%;" viewBox="0 0 100 100" fill="none">
			<circle cx="50" cy="50" r="48" stroke="#4a9a6d" stroke-width="0.6"></circle>
			<circle cx="35" cy="35" r="6" fill="#3a7a4d" opacity="0.5"></circle>
			<circle cx="65" cy="65" r="4" fill="#3a7a4d" opacity="0.4"></circle>
		</svg>
	</div>

	<div class="relative z-10 mx-auto w-full max-w-6xl px-6 py-20">
		<div class="flex flex-col items-center text-center">
			<h1 class="about-name font-light tracking-tighter text-[#f0e6d2]" style="font-size: clamp(2.5rem, 10vw, 8rem);">
				{t("about.name")}
			</h1>
			<p class="about-subtitle mt-6 text-xs uppercase tracking-[0.3em] text-[#6b6055]">
				{t("about.role")}
			</p>
		</div>

		<div class="mx-auto mt-16 max-w-2xl">
			<div class="code-block relative p-8 font-mono text-sm leading-relaxed" style="border-color: rgba(240,230,210,0.06); color: #a89a84; min-height: 200px; overflow: hidden;">
				<div class="bio-lines space-y-2" style="min-height: 160px;">
					<p class="bio-line" style="overflow-wrap: break-word; word-break: break-word;"><span style="color: #f0e6d2;">{t("about.identity")}:</span> <span class="bio-value">{t("about.name")}</span></p>
					<p class="bio-line" style="overflow-wrap: break-word; word-break: break-word;"><span style="color: #f0e6d2;">{t("about.class")}:</span> <span class="bio-value">{t("about.role")}</span></p>
					<p class="bio-line" style="overflow-wrap: break-word; word-break: break-word;"><span style="color: #f0e6d2;">{t("about.location")}:</span> <span class="bio-value">{t("about.locationValue")}</span></p>
					<p class="bio-line" style="overflow-wrap: break-word; word-break: break-word;"><span style="color: #f0e6d2;">{t("about.status")}:</span> <span class="bio-value">{t("about.statusValue")}</span></p>
					<p class="bio-line pt-2 italic" style="color: #6b6055; overflow-wrap: break-word; word-break: break-word;">{t("about.quote")}</p>
				</div>
			</div>
		</div>
	</div>
</section>

<style>
	.about-name { visibility: hidden }

	@keyframes terminal-blink {
		0%, 49% { opacity: 1; }
		50%, 100% { opacity: 0; }
	}

	.bio-cursor {
		display: inline-block;
		width: 0.6em;
		height: 1em;
		background-color: #3a7a4d;
		vertical-align: text-bottom;
		animation: terminal-blink 1s step-end infinite;
	}
	.about-decor svg {
		will-change: transform, opacity;
	}
</style>

<script>
	import gsap from "gsap"
	import { ScrollTrigger } from "gsap/ScrollTrigger"
	import { SplitText } from "gsap/SplitText"
	import { ScrambleTextPlugin } from "gsap/ScrambleTextPlugin"
	import { DrawSVGPlugin } from "gsap/DrawSVGPlugin"

	gsap.registerPlugin(ScrollTrigger, SplitText, ScrambleTextPlugin, DrawSVGPlugin)

	let ctx: gsap.Context | null = null

	function init() {
		if (ctx) {
			ctx.revert()
		}

		ctx = gsap.context(() => {
			const nameSplit = new SplitText(".about-name", { type: "chars" })
			gsap.set(".about-name", { visibility: "visible" })

			const bioLines = document.querySelectorAll<HTMLElement>(".bio-line")
			gsap.set(bioLines, { opacity: 0 })
			gsap.set(".about-subtitle", { opacity: 0, y: 20 })
			gsap.set(".about-decor svg", { opacity: 0 })

			// Insert blinking cursor at end of last bio line
			const lastLine = bioLines[bioLines.length - 1]
			const cursor = document.createElement("span")
			cursor.className = "bio-cursor"
			lastLine.appendChild(cursor)

			const tl = gsap.timeline({
				defaults: { ease: "power3.out" },
				paused: true,
				scrollTrigger: {
					trigger: "#about",
					start: "top bottom",
					end: "bottom top",
					pin: true,
					onEnter: () => tl.play(),
				},
			})

			tl.from(nameSplit.chars, { y: "100%", opacity: 0, stagger: 0.018 })

			tl.from(".about-subtitle", { opacity: 0, y: 20 }, 0.12)

			// Cursor appears alongside the decode
			tl.from(cursor, { autoAlpha: 0, duration: 0.1 }, 0.15)

			tl.fromTo(
				".about-circle-main circle",
				{ drawSVG: "0%" },
				{ drawSVG: "100%", duration: 0.5, stagger: 0.08 },
				0.18
			)
			tl.fromTo(
				".about-circle-cross circle, .about-circle-cross line",
				{ drawSVG: "0%" },
				{ drawSVG: "100%", duration: 0.4, stagger: 0.06 },
				0.28
			)
			tl.fromTo(
				".about-circle-accent circle",
				{ drawSVG: "0%" },
				{ drawSVG: "100%", duration: 0.3, stagger: 0.05 },
				0.34
			)
			tl.to(".about-decor svg", { opacity: 0, duration: 0.01 }, 0)
			tl.to(".about-decor svg", { opacity: 1, duration: 0.01 }, 0.16)

			const scrambleChars = "▪░▒▓█"
			const texts = Array.from(bioLines).map((l) => l.textContent || "")
			const maxLen = Math.max(...texts.map((t) => t.length))
			const sharedDur = Math.max(maxLen * 0.014 + 0.15, 0.45)

			bioLines.forEach((line, i) => {
				tl.to(line, { opacity: 1, duration: 0.01 }, 0.25)
				tl.to(line, {
					duration: sharedDur,
					// @ts-ignore
					scrambleText: {
						text: texts[i],
						chars: scrambleChars,
						revealDelay: 0,
						speed: 0.7,
					},
					ease: "none",
				}, 0.25)
			})
		}, "#about")
	}

	init()
	document.addEventListener("astro:after-swap", () => {
		init()
		ScrollTrigger.refresh()
	})
</script>
