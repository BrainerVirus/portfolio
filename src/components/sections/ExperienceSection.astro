---
import { getLangFromUrl, useTranslation } from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const exp = useTranslation(lang, "experience")
---

<section
	class="relative mx-auto flex min-h-screen max-w-5xl items-center scroll-mt-24 overflow-hidden bg-[#0a0e0a] px-6"
	id="experience"
>
	<div class="w-full py-24">
		{/* Background geometric shapes */}
		<div class="experience-bg pointer-events-none absolute inset-0 overflow-hidden">
			<svg
				class="experience-shape absolute -left-32 top-20 h-[500px] w-[500px] opacity-[0.04]"
				viewBox="0 0 500 500"
				fill="none"
			>
				<circle cx="250" cy="250" r="248" stroke="#f0e6d2" stroke-width="1"></circle>
			</svg>
			<svg
				class="experience-shape absolute -right-40 top-[40%] h-[600px] w-[600px] opacity-[0.03]"
				viewBox="0 0 600 600"
				fill="none"
			>
				<circle cx="300" cy="300" r="298" stroke="#f0e6d2" stroke-width="1"></circle>
				<circle cx="300" cy="300" r="200" stroke="#f0e6d2" stroke-width="0.5"></circle>
			</svg>
			<svg
				class="experience-shape absolute -left-20 bottom-32 h-[400px] w-[400px] opacity-[0.03]"
				viewBox="0 0 400 400"
				fill="none"
			>
				<line
					x1="0"
					y1="200"
					x2="400"
					y2="200"
					stroke="#f0e6d2"
					stroke-width="0.5"></line>
				<line
					x1="200"
					y1="0"
					x2="200"
					y2="400"
					stroke="#f0e6d2"
					stroke-width="0.5"></line>
			</svg>
		</div>

		<div class="relative z-10 mb-20">
			<h2
				class="section-heading text-4xl font-medium tracking-tight text-[#f0e6d2] md:text-5xl"
			>
				{exp.title}
			</h2>
			<p class="experience-subtitle mt-4 max-w-xl text-lg text-[#a89a84]">
				{exp.subtitle}
			</p>
		</div>

		<div class="experience-entries relative z-10 space-y-12">
			{
				exp.jobs.map((job, index) => (
					<div
						class="experience-entry group grid grid-cols-1 gap-6 border-l-2 border-transparent py-4 pl-6 md:grid-cols-2 md:gap-16 md:pl-8"
						data-index={index}
					>
						<div>
							<h3 class="text-2xl font-medium text-[#f0e6d2]">{job.company}</h3>
							<div class="mt-1 text-lg text-[#a89a84]">{job.title}</div>
						</div>
						<div>
							<div class="font-mono text-xs tracking-widest text-[#6b6055]">
								{job.period}
							</div>
							<p class="mt-3 text-base leading-relaxed text-[#a89a84]">
								{job.description}
							</p>
							<div class="mt-4 flex flex-wrap gap-2">
								{job.tags.map((tag) => (
									<span class="border border-[#a89a84]/20 px-2 py-1 font-mono text-[10px] tracking-wider text-[#6b6055] uppercase">
										{tag}
									</span>
								))}
							</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<style>
	.experience-entry {
		will-change: transform;
		padding: 1.5rem;
		border-radius: 0.75rem;
		background: rgba(20, 26, 20, 0.3);
	}

	.experience-subtitle { opacity: 0 }
</style>

<script>
	import gsap from "gsap"
	import { ScrollTrigger } from "gsap/ScrollTrigger"
	import { SplitText } from "gsap/SplitText"
	import { initCardTilt } from "@/lib/animations"

	gsap.registerPlugin(ScrollTrigger, SplitText)

	let ctx: gsap.Context | null = null
	let currentSplit: SplitText | null = null
	let tiltCleanup: (() => void) | null = null

	function initExperienceAnimations() {
		if (currentSplit) {
			currentSplit.revert()
			currentSplit = null
		}
		if (tiltCleanup) {
			tiltCleanup()
			tiltCleanup = null
		}
		if (ctx) {
			ctx.revert()
		}

		ctx = gsap.context(() => {
			const heading = document.querySelector("#experience .section-heading")
			if (heading) {
				currentSplit = new SplitText(heading, {
					type: "lines",
					linesClass: "split-line overflow-hidden",
				})
				gsap.from(currentSplit.lines, {
					yPercent: 100,
					opacity: 0,
					duration: 0.8,
					stagger: 0.1,
					ease: "power3.out",
					scrollTrigger: {
						trigger: heading,
						start: "top 85%",
					},
				})
			}

			const subtitle = document.querySelector("#experience .experience-subtitle")
			if (subtitle) {
				gsap.from(subtitle, {
					opacity: 0,
					y: 20,
					duration: 0.7,
					delay: 0.2,
					ease: "power3.out",
					scrollTrigger: {
						trigger: heading || subtitle,
						start: "top 85%",
					},
				})
			}

			const cards = gsap.utils.toArray<HTMLElement>(".experience-entry")
			cards.forEach((card, i) => {
				gsap.from(card, {
					y: 60,
					opacity: 0,
					duration: 0.7,
					delay: i * 0.1,
					ease: "power3.out",
					scrollTrigger: {
						trigger: card,
						start: "top 88%",
					},
				})
			})

			const bg = document.querySelector(".experience-bg")
			if (bg) {
				gsap.from(bg, {
					opacity: 0,
					duration: 1,
					scrollTrigger: {
						trigger: "#experience",
						start: "top 80%",
					},
				})
			}
		}, "#experience")

		// 3D tilt effect
		const section = document.querySelector("#experience")
		if (section) {
			tiltCleanup = initCardTilt(section, { maxTilt: 12, perspective: 1000 })
		}
	}

	initExperienceAnimations()
	document.addEventListener("astro:after-swap", () => {
		initExperienceAnimations()
	})
</script>
