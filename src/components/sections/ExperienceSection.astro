---
import { getLangFromUrl, useTranslation } from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const exp = useTranslation(lang, "experience")
---

<section
	class="relative mx-auto flex min-h-screen max-w-5xl items-center scroll-mt-24 px-6"
	id="experience"
>
	<div class="w-full py-24">
		<div class="experience-bg pointer-events-none absolute inset-0 overflow-visible">
			<svg
				class="experience-shape experience-shape--primary absolute -left-40 -top-40 h-[640px] w-[640px] opacity-[0.055]"
				viewBox="0 0 500 500"
				fill="none"
			>
				<circle cx="250" cy="250" r="248" stroke="#f0e6d2" stroke-width="1"></circle>
				<circle cx="250" cy="250" r="180" stroke="#f0e6d2" stroke-width="0.4" stroke-dasharray="6 4"></circle>
			</svg>
			<svg
				class="experience-shape absolute -right-40 top-[40%] h-[600px] w-[600px] opacity-[0.03]"
				viewBox="0 0 600 600"
				fill="none"
			>
				<circle cx="300" cy="300" r="298" stroke="#f0e6d2" stroke-width="1"></circle>
				<circle cx="300" cy="300" r="200" stroke="#f0e6d2" stroke-width="0.5"></circle>
				<circle cx="300" cy="300" r="120" stroke="#f0e6d2" stroke-width="0.3" stroke-dasharray="8 8"></circle>
			</svg>
			<svg
				class="experience-shape absolute -left-20 bottom-32 h-[400px] w-[400px] opacity-[0.03]"
				viewBox="0 0 400 400"
				fill="none"
			>
				<line x1="0" y1="200" x2="400" y2="200" stroke="#f0e6d2" stroke-width="0.5"></line>
				<line x1="200" y1="0" x2="200" y2="400" stroke="#f0e6d2" stroke-width="0.5"></line>
				<circle cx="200" cy="200" r="180" stroke="#f0e6d2" stroke-width="0.3"></circle>
			</svg>
		</div>

		<div class="relative z-10 mb-16">
			<h2
				class="section-heading text-4xl font-medium tracking-tight text-[#f0e6d2] md:text-5xl"
				data-i18n="experience.title"
			>
				{exp.title}
			</h2>
			<p class="experience-subtitle mt-4 max-w-xl text-lg text-[#a89a84]" data-i18n="experience.subtitle">
				{exp.subtitle}
			</p>
		</div>

		<div class="experience-entries relative z-10 space-y-8">
			{
				exp.jobs.map((job, index) => (
					<div class="experience-card-wrapper" style="perspective: 1200px; overflow: visible;">
						<div
							class="experience-entry group relative cursor-pointer"
							data-index={index}
						>
							<div class="experience-glow pointer-events-none absolute inset-0 rounded-xl" style="opacity: 0; background: radial-gradient(circle 180px at var(--gx, 50%) var(--gy, 50%), rgba(58,122,77,0.12), transparent 70%);"></div>
							<div class="experience-card-content grid grid-cols-1 gap-6 border-l-2 border-transparent p-6 md:grid-cols-2 md:gap-16">
								<div>
									<h3 class="text-2xl font-medium text-[#f0e6d2]" data-i18n={`experience.jobs.${index}.company`}>{job.company}</h3>
									<div class="mt-1 text-lg text-[#a89a84]" data-i18n={`experience.jobs.${index}.title`}>{job.title}</div>
								</div>
								<div>
									<div class="font-mono text-xs tracking-widest text-[#6b6055]" data-i18n={`experience.jobs.${index}.period`}>
										{job.period}
									</div>
									<p class="mt-3 text-base leading-relaxed text-[#a89a84]" data-i18n={`experience.jobs.${index}.description`}>
										{job.description}
									</p>
									<div class="mt-4 flex flex-wrap gap-2">
										{job.tags.map((tag, tagIndex) => (
											<span class="border border-[#a89a84]/20 px-2 py-1 font-mono text-[10px] tracking-wider text-[#6b6055] uppercase" data-i18n={`experience.jobs.${index}.tags.${tagIndex}`}>
												{tag}
											</span>
										))}
									</div>
								</div>
							</div>
						</div>
					</div>
				))
			}
		</div>
	</div>
</section>

<div class="experience-modal pointer-events-none fixed inset-0 z-50 flex items-center justify-center opacity-0" style="background: rgba(10,14,10,0.92); transition: opacity 0.4s ease;">
	<div class="experience-modal-card relative cursor-default" style="width: 460px; max-height: 80vh; perspective: 3000px; transform-style: preserve-3d;">
		<div class="experience-modal-inner" style="transform-style: preserve-3d;">
			<div class="experience-modal-glow pointer-events-none absolute inset-0 rounded-2xl z-10" style="opacity: 0; background: radial-gradient(circle 200px at var(--mgx, 50%) var(--mgy, 50%), rgba(58,122,77,0.10), transparent 70%); transition: opacity 0.3s ease;"></div>
			<div class="experience-modal-front rounded-2xl p-8" style="background: rgba(20,26,20,0.95); border: 1px solid rgba(58,122,77,0.3); backface-visibility: hidden;">
				<div class="experience-modal-content"></div>
			</div>
			<div class="experience-modal-back absolute inset-0 rounded-2xl p-8 flex flex-col items-center justify-center overflow-hidden" style="background: radial-gradient(circle at 50% 12%, rgba(58,122,77,0.18), #0a0e0a 56%); border: 1px solid rgba(58,122,77,0.5); backface-visibility: hidden; transform: rotateY(180deg);">
				<svg class="arcana-sky mb-5 h-40 w-40 overflow-visible" viewBox="0 0 160 160" fill="none" aria-hidden="true">
					<path class="arcana-line" d="M28 112 L48 52 L80 28 L112 58 L132 110 L92 98 L60 126 Z" stroke="#f0e6d2" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" opacity="0.65"></path>
					<path class="arcana-line" d="M48 52 L92 98 L112 58 M80 28 L60 126" stroke="#3a7a4d" stroke-width="1" stroke-linecap="round" opacity="0.85"></path>
					<g class="arcana-stars" fill="#f0e6d2">
						<circle cx="28" cy="112" r="2.5"></circle>
						<circle cx="48" cy="52" r="2.5"></circle>
						<circle cx="80" cy="28" r="3"></circle>
						<circle cx="112" cy="58" r="2.5"></circle>
						<circle cx="132" cy="110" r="2.5"></circle>
						<circle cx="92" cy="98" r="2.5"></circle>
						<circle cx="60" cy="126" r="2.5"></circle>
					</g>
				</svg>
				<p class="mb-2 font-mono text-[10px] tracking-[0.3em] text-[#6b6055] uppercase" data-arcana-constellation></p>
				<h3 class="text-center text-2xl font-medium text-[#f0e6d2]" data-arcana-name></h3>
				<p class="mt-4 text-center font-mono text-sm leading-relaxed text-[#3a7a4d]" data-arcana-reward></p>
			</div>
		</div>
	</div>
	<button class="experience-modal-close absolute top-6 right-6 text-[#a89a84] text-3xl hover:text-[#f0e6d2] transition-colors cursor-pointer" data-i18n-aria-label="experience.close" aria-label={exp.close}>&times;</button>
	<button class="experience-modal-flip absolute bottom-8 left-1/2 -translate-x-1/2 border border-[#3a7a4d]/40 rounded-full px-5 py-2.5 font-mono text-xs text-[#3a7a4d] hover:bg-[#3a7a4d]/10 hover:border-[#3a7a4d]/60 transition-colors cursor-pointer" data-i18n="experience.flip">{exp.flip}</button>
</div>

<style>
	.experience-card-wrapper {
		perspective: 1200px;
		overflow: visible;
		padding: 24px 0;
		opacity: 0;
	}

	.experience-entry {
		transform-style: preserve-3d;
		padding: 0;
		border-radius: 0.75rem;
		background: rgba(20, 26, 20, 0.4);
		backdrop-filter: blur(8px);
		border: 1px solid rgba(240, 230, 210, 0.06);
		transition: box-shadow 0.3s ease;
	}

	.experience-entry:hover {
		box-shadow: 0 10px 40px rgba(0, 0, 0, 0.3);
	}

	.experience-subtitle { opacity: 0 }
</style>

<script>
	import gsap from "gsap"
	import { ScrollTrigger } from "gsap/ScrollTrigger"
	import { SplitText } from "gsap/SplitText"
	import { DrawSVGPlugin } from "gsap/DrawSVGPlugin"
	import {
		getCurrentLanguage,
		getTranslation,
		languageChangeEvent,
		type Language,
	} from "@/lib/live-language"

	gsap.registerPlugin(ScrollTrigger, SplitText, DrawSVGPlugin)

	let ctx: gsap.Context | null = null
	let currentSplit: SplitText | null = null
	let tiltCleanups: (() => void)[] = []
	let drawSVGDone = false

	function initPerCardTilt(card: HTMLElement): () => void {
		card.style.transformStyle = "preserve-3d"

		const xTo = gsap.quickTo(card, "rotationX", { duration: 0.6, ease: "power2.out" })
		const yTo = gsap.quickTo(card, "rotationY", { duration: 0.6, ease: "power2.out" })
		const glow = card.querySelector<HTMLElement>(".experience-glow")
		const glowOpacityTo = glow ? gsap.quickTo(glow, "opacity", { duration: 0.3, ease: "power2.out" }) : null

		const onMove = (e: MouseEvent) => {
			const rect = card.getBoundingClientRect()
			const rx = (e.clientX - rect.left) / rect.width - 0.5
			const ry = (e.clientY - rect.top) / rect.height - 0.5
			yTo(rx * 20)
			xTo(ry * -20)
			if (glow) {
				glow.style.setProperty("--gx", `${e.clientX - rect.left}px`)
				glow.style.setProperty("--gy", `${e.clientY - rect.top}px`)
				glowOpacityTo?.(1)
			}
		}
		const onLeave = () => {
			xTo(0)
			yTo(0)
			glowOpacityTo?.(0)
		}

		card.addEventListener("mousemove", onMove)
		card.addEventListener("mouseleave", onLeave)

		return () => {
			card.removeEventListener("mousemove", onMove)
			card.removeEventListener("mouseleave", onLeave)
			xTo(0)
			yTo(0)
			glowOpacityTo?.(0)
		}
	}

	function initExperienceAnimations() {
		if (currentSplit) { currentSplit.revert(); currentSplit = null }
		tiltCleanups.forEach((c) => c())
		tiltCleanups = []

		const section = document.querySelector("#experience")
		if (!section) return

		// Only create fresh context on first load (not on swap — avoids SVG flicker)
		if (!ctx) {
			ctx = gsap.context(() => {
				const heading = section.querySelector<HTMLElement>(".section-heading")
				if (heading) {
					currentSplit = new SplitText(heading, {
						type: "lines",
						linesClass: "split-line overflow-hidden",
					})
					gsap.from(currentSplit.lines, {
						yPercent: 100, opacity: 0, duration: 0.8, stagger: 0.1, ease: "power3.out",
						scrollTrigger: { trigger: heading, start: "top 85%", once: true },
					})
				}

				const subtitle = section.querySelector<HTMLElement>(".experience-subtitle")
				if (subtitle) {
					gsap.fromTo(
						subtitle,
						{ autoAlpha: 0, y: 20 },
						{
							autoAlpha: 1,
							y: 0,
							duration: 0.7,
							ease: "power3.out",
							scrollTrigger: { trigger: subtitle, start: "top 90%", once: true },
						}
					)
				}

				const wrappers = gsap.utils.toArray<HTMLElement>(".experience-card-wrapper")
				gsap.set(wrappers, { autoAlpha: 0, y: 56 })
				gsap.set(".experience-card-content", { autoAlpha: 0, y: 10 })
				ScrollTrigger.batch(wrappers, {
					once: true,
					start: "top 88%",
					onEnter: (batch) => {
						const content = batch
							.map((wrapper) => wrapper.querySelector<HTMLElement>(".experience-card-content"))
							.filter((el): el is HTMLElement => Boolean(el))

						gsap.to(batch, {
							autoAlpha: 1,
							y: 0,
							duration: 0.7,
							ease: "power3.out",
							stagger: 0.1,
							overwrite: true,
						})
						gsap.to(content, {
							autoAlpha: 1,
							y: 0,
							duration: 0.45,
							delay: 0.1,
							ease: "power2.out",
							stagger: 0.08,
							overwrite: true,
						})
					},
				})
		}, "#experience")
		}

		// Standalone drawSVG — created once, never duplicated on swap
		if (!drawSVGDone) {
			drawSVGDone = true
			const shapes = section.querySelectorAll<HTMLElement>(
				".experience-shape circle, .experience-shape line"
			)
			gsap.fromTo(shapes,
				{ drawSVG: "0% 0%" },
				{
					drawSVG: "0% 100%",
					duration: 1.5,
					ease: "power2.inOut",
					scrollTrigger: {
						trigger: section,
						start: "top 92%",
						end: "center 35%",
						scrub: true,
					},
				}
			)
		}

		const entries = section.querySelectorAll<HTMLElement>(".experience-entry")
		entries.forEach((card) => {
			tiltCleanups.push(initPerCardTilt(card))
		})
	}

	initExperienceAnimations()
	document.addEventListener("astro:after-swap", () => { initExperienceAnimations() })

	// --- Modal overlay with flip easter egg ---
	const modal = document.querySelector(".experience-modal") as HTMLElement
	const modalCard = modal.querySelector(".experience-modal-card") as HTMLElement
	const modalInner = modal.querySelector(".experience-modal-inner") as HTMLElement
	const modalFront = modal.querySelector(".experience-modal-content") as HTMLElement
	const modalArcanaName = modal.querySelector<HTMLElement>("[data-arcana-name]")!
	const modalArcanaConstellation = modal.querySelector<HTMLElement>("[data-arcana-constellation]")!
	const modalArcanaReward = modal.querySelector<HTMLElement>("[data-arcana-reward]")!
	const modalClose = modal.querySelector(".experience-modal-close") as HTMLElement
	const modalFlip = modal.querySelector(".experience-modal-flip") as HTMLElement
	const arcanaLines = modal.querySelectorAll<SVGPathElement>(".arcana-line")
	const arcanaStars = modal.querySelectorAll<SVGCircleElement>(".arcana-stars circle")
	let modalFlipped = false
	let activeArcanaIndex = 0

	function initModalTilt(): () => void {
		// Tilt the INNER wrapper (keeps rotationY free for flip on outer card)
		const xTo = gsap.quickTo(modalInner, "rotationX", { duration: 0.5, ease: "power2.out" })
		const yTo = gsap.quickTo(modalInner, "rotationY", { duration: 0.5, ease: "power2.out" })
		const glow = modal.querySelector<HTMLElement>(".experience-modal-glow")

		const onMove = (e: MouseEvent) => {
			const rect = modalCard.getBoundingClientRect()
			const rx = (e.clientX - rect.left) / rect.width - 0.5
			const ry = (e.clientY - rect.top) / rect.height - 0.5
			yTo(rx * 15)
			xTo(ry * -15)
			if (glow) {
				glow.style.setProperty("--mgx", `${e.clientX - rect.left}px`)
				glow.style.setProperty("--mgy", `${e.clientY - rect.top}px`)
				glow.style.opacity = "1"
			}
		}
		const onLeave = () => {
			xTo(0)
			yTo(0)
			if (glow) glow.style.opacity = "0"
		}

		modalCard.addEventListener("mousemove", onMove)
		modalCard.addEventListener("mouseleave", onLeave)

		return () => {
			modalCard.removeEventListener("mousemove", onMove)
			modalCard.removeEventListener("mouseleave", onLeave)
			xTo(0)
			yTo(0)
		}
	}
	let modalTiltCleanup: (() => void) | null = null

	function renderArcana(index: number, lang: Language = getCurrentLanguage()) {
		const arcanaIndex = index % 4
		modalArcanaName.textContent = getTranslation(lang, `experience.arcana.${arcanaIndex}.name`)
		modalArcanaConstellation.textContent = getTranslation(
			lang,
			`experience.arcana.${arcanaIndex}.constellation`
		)
		modalArcanaReward.textContent = getTranslation(lang, `experience.arcana.${arcanaIndex}.reward`)
	}

	function revealArcana() {
		gsap.fromTo(
			arcanaLines,
			{ drawSVG: "0% 0%" },
			{ drawSVG: "0% 100%", duration: 0.85, stagger: 0.08, ease: "power2.inOut" }
		)
		gsap.fromTo(
			arcanaStars,
			{ scale: 0, autoAlpha: 0, transformOrigin: "50% 50%" },
			{ scale: 1, autoAlpha: 1, duration: 0.45, stagger: 0.04, ease: "back.out(2)" }
		)
		gsap.fromTo(
			[modalArcanaConstellation, modalArcanaName, modalArcanaReward],
			{ y: 12, autoAlpha: 0 },
			{ y: 0, autoAlpha: 1, duration: 0.45, stagger: 0.08, ease: "power2.out" }
		)
		gsap.fromTo(
			modalCard,
			{ boxShadow: "0 0 0 rgba(58,122,77,0)" },
			{
				boxShadow: "0 0 90px rgba(58,122,77,0.35)",
				duration: 0.35,
				yoyo: true,
				repeat: 1,
				ease: "power2.out",
			}
		)
	}

	function openModal(card: HTMLElement) {
		const i = parseInt(card.dataset.index || "0", 10)
		activeArcanaIndex = i
		const grid = card.querySelector(".grid")
		if (grid) {
			const clone = grid.cloneNode(true) as HTMLElement
			// Force single-column layout in modal
			clone.classList.add("!grid-cols-1")
			clone.classList.remove("md:grid-cols-2", "md:gap-16", "p-6")
			clone.classList.add("!p-0")
			modalFront.innerHTML = ""
			modalFront.appendChild(clone)
		}
		renderArcana(i)
		modal.style.pointerEvents = "auto"
		modal.style.opacity = "1"
		modalFlipped = false
		gsap.set(modalCard, { rotationY: 0 })
		gsap.set(modalInner, { rotationX: 0, rotationY: 0 })
		gsap.set(arcanaLines, { drawSVG: "0% 0%" })
		gsap.set(arcanaStars, { scale: 0, autoAlpha: 0, transformOrigin: "50% 50%" })
		gsap.set([modalArcanaConstellation, modalArcanaName, modalArcanaReward], { autoAlpha: 0 })
		modalTiltCleanup = initModalTilt()
	}

	function closeModal() {
		modal.style.pointerEvents = "none"
		modal.style.opacity = "0"
		if (modalTiltCleanup) { modalTiltCleanup(); modalTiltCleanup = null }
	}

	modalClose.addEventListener("click", closeModal)
	modal.addEventListener("click", (e) => {
		if (e.target === modal) closeModal()
	})
	document.addEventListener("keydown", (e) => {
		if (e.key === "Escape" && modal.style.opacity === "1") closeModal()
	})

	modalFlip.addEventListener("click", () => {
		modalFlipped = !modalFlipped
		gsap.to(modalCard, {
			rotationY: modalFlipped ? 180 : 0,
			duration: 0.7,
			ease: "power2.inOut",
			onComplete: () => {
				if (modalFlipped) revealArcana()
			},
		})
	})

	document.addEventListener(languageChangeEvent, (event) => {
		const detail = (event as CustomEvent).detail
		if (!detail) return
		renderArcana(activeArcanaIndex, detail.language)
	})

	// Wire cards to modal
	const entries = document.querySelectorAll<HTMLElement>("#experience .experience-entry")
	entries.forEach((card) => {
		card.addEventListener("click", () => openModal(card))
	})
</script>
