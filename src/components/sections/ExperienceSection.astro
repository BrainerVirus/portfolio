---
import { getLangFromUrl, useTranslation } from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const exp = useTranslation(lang, "experience")

interface Experience {
	title: string
	company: string
	description: string
	tags: string[]
	period: string
	isFirst?: boolean
}

// Ahora usamos las tags que vienen directamente de la traducción
const experiences: Experience[] = exp.jobs.map((job, index) => ({
	...job,
	tags: [...job.tags],
	isFirst: index === 0,
}))
---

<section class="relative mx-auto max-w-5xl scroll-mt-24 px-6 py-12" id="experience">
	<div class="mb-16 flex flex-col items-center text-center">
		<div
			class="animate-float border-primary/30 bg-primary/10 mb-4 inline-flex items-center justify-center rounded-full border p-3"
		>
			<span class="material-symbols-outlined text-primary">history_edu</span>
		</div>
		<h2
			class="bg-linear-to-r from-white to-gray-400 bg-clip-text pb-2 text-4xl font-bold text-transparent md:text-5xl"
		>
			{exp.title}
		</h2>
		<p class="mt-2 max-w-lg text-gray-400">
			{exp.subtitle}
		</p>
	</div>
	<div class="relative">
		<div class="timeline-line absolute top-0 bottom-0 left-4 z-0 -ml-px w-0.5 md:left-1/2"></div>
		<div class="space-y-16">
			{
				experiences.map((exp, index) => (
					<div class="group relative grid gap-8 md:grid-cols-2 md:gap-16">
						{index % 2 === 0 ? (
							<>
								<div class="relative order-2 pl-12 md:order-1 md:pl-0 md:text-right">
									<div class="experience-card glass-card hover:border-primary/60 rounded-xl p-6 transition-[border-color,box-shadow,translate] duration-300 hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(131,59,145,0.25)]">
										<h3 class="mb-1 text-xl font-bold text-white">{exp.title}</h3>
										<div class="text-primary mb-3 font-medium">{exp.company}</div>
										<p class="font-body text-sm leading-relaxed text-gray-400">{exp.description}</p>
										<div class="mt-4 flex flex-wrap gap-2 md:justify-end">
											{exp.tags.map((tag) => (
												<span class="rounded border border-white/10 bg-white/5 px-2 py-1 text-xs text-gray-300">
													{tag}
												</span>
											))}
										</div>
									</div>
								</div>
								<div
									class={`border-background-dark absolute top-6 left-4 z-10 -ml-2 h-4 w-4 rounded-full border-2 md:top-1/2 md:left-1/2 md:-mt-2 ${
										exp.isFirst
											? "bg-primary shadow-[0_0_15px_#833b91]"
											: "bg-primary/70 group-hover:bg-primary shadow-[0_0_10px_#833b91] transition-[background-color,box-shadow] duration-150 group-hover:shadow-[0_0_20px_#833b91]"
									}`}
								/>
								<div class="order-1 flex items-center pl-12 md:order-2 md:justify-start md:pl-0">
									<span class="font-display group-hover:text-primary/40 text-2xl font-bold text-white/20 transition-colors md:text-4xl">
										{exp.period}
									</span>
								</div>
							</>
						) : (
							<>
								<div class="order-1 flex items-center pl-12 md:justify-end md:pl-0 md:text-right">
									<span class="font-display group-hover:text-primary/40 text-2xl font-bold text-white/20 transition-colors md:text-4xl">
										{exp.period}
									</span>
								</div>
								<div class="border-background-dark bg-primary/70 group-hover:bg-primary absolute top-6 left-4 z-10 -ml-2 h-4 w-4 rounded-full border-2 shadow-[0_0_10px_#833b91] transition-[background-color,box-shadow] duration-150 group-hover:shadow-[0_0_20px_#833b91] md:top-1/2 md:left-1/2 md:-mt-2" />
								<div class="relative order-2 pl-12 md:pl-0">
									<div class="experience-card glass-card hover:border-primary/60 rounded-xl p-6 transition-[border-color,box-shadow,translate] duration-300 hover:-translate-y-1 hover:shadow-[0_0_30px_rgba(131,59,145,0.25)]">
										<h3 class="mb-1 text-xl font-bold text-white">{exp.title}</h3>
										<div class="text-primary mb-3 font-medium">{exp.company}</div>
										<p class="font-body text-sm leading-relaxed text-gray-400">{exp.description}</p>
										<div class="mt-4 flex flex-wrap gap-2">
											{exp.tags.map((tag) => (
												<span class="rounded border border-white/10 bg-white/5 px-2 py-1 text-xs text-gray-300">
													{tag}
												</span>
											))}
										</div>
									</div>
								</div>
							</>
						)}
					</div>
				))
			}
		</div>
	</div>
</section>

<script>
	import gsap from "gsap"
	import { ScrollTrigger } from "gsap/ScrollTrigger"
	gsap.registerPlugin(ScrollTrigger)

	function initExperienceCards() {
		const cards = document.querySelectorAll(".experience-card")
		let activeCard: Element | null = null

		// Only apply touch behavior on touch devices
		const isTouchDevice = "ontouchstart" in window || navigator.maxTouchPoints > 0

		if (!isTouchDevice) return

		cards.forEach((card) => {
			card.addEventListener("touchstart", () => {
				// If tapping the same card, toggle off
				if (activeCard === card) {
					card.classList.remove("touch-active")
					activeCard = null
				} else {
					// Remove active state from previous card
					if (activeCard) {
						activeCard.classList.remove("touch-active")
					}
					// Activate this card
					card.classList.add("touch-active")
					activeCard = card
				}
			})
		})

		// Remove active state when tapping outside cards or scrolling
		document.addEventListener("touchstart", (e) => {
			const target = e.target as Element
			if (activeCard && !target.closest(".experience-card")) {
				activeCard.classList.remove("touch-active")
				activeCard = null
			}
		})

		// Remove active state on scroll
		let scrollTimeout: ReturnType<typeof setTimeout>
		window.addEventListener(
			"scroll",
			() => {
				if (activeCard) {
					clearTimeout(scrollTimeout)
					scrollTimeout = setTimeout(() => {
						if (activeCard) {
							activeCard.classList.remove("touch-active")
							activeCard = null
						}
					}, 100)
				}
			},
			{ passive: true }
		)
	}

	function initExperienceAnimations() {
		const cards = document.querySelectorAll("#experience .experience-card")
		const periods = document.querySelectorAll("#experience .font-display")

		// Staggered card slide-in from alternating directions
		cards.forEach((card, i) => {
			const isLeft = i % 2 === 0
			gsap.fromTo(
				card,
				{ opacity: 0, x: isLeft ? -50 : 50 },
				{
					opacity: 1,
					x: 0,
					duration: 0.7,
					delay: i * 0.15,
					ease: "power3.out",
					scrollTrigger: {
						trigger: card,
						start: "top 85%",
						toggleActions: "play none none none",
					},
				}
			)
		})

		// Period text scale in
		periods.forEach((period, i) => {
			gsap.fromTo(
				period,
				{ opacity: 0, scale: 0.8 },
				{
					opacity: 1,
					scale: 1,
					duration: 0.5,
					delay: i * 0.15 + 0.3,
					ease: "back.out(1.5)",
					scrollTrigger: {
						trigger: period,
						start: "top 85%",
						toggleActions: "play none none none",
					},
				}
			)
		})

		// Section heading fade-in
		const heading = document.querySelector("#experience .mb-16")
		if (heading) {
			gsap.fromTo(
				heading.children,
				{ opacity: 0, y: 30 },
				{
					opacity: 1,
					y: 0,
					duration: 0.6,
					stagger: 0.15,
					ease: "power2.out",
					scrollTrigger: {
						trigger: heading,
						start: "top 85%",
						toggleActions: "play none none none",
					},
				}
			)
		}
	}

	// Initialize on page load
	initExperienceCards()
	initExperienceAnimations()

	// Re-initialize after Astro view transitions
	document.addEventListener("astro:after-swap", () => {
		initExperienceCards()
		setTimeout(initExperienceAnimations, 100)
	})
</script>
