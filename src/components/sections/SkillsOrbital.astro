---
import { getLangFromUrl, getTranslations } from "@/i18n/utils"
import { Icon } from "astro-icon/components"

const lang = getLangFromUrl(Astro.url)
const t = getTranslations(lang)

interface Skill {
	translationKey: string
	mastery: number
	icon: string
}

const coreSkills: Skill[] = [
	{ translationKey: "skills.core_skills.typescript", mastery: 95, icon: "simple-icons:typescript" },
	{ translationKey: "skills.core_skills.javascript", mastery: 90, icon: "simple-icons:javascript" },
	{ translationKey: "skills.core_skills.angular", mastery: 90, icon: "simple-icons:angular" },
	{ translationKey: "skills.core_skills.react", mastery: 90, icon: "simple-icons:react" },
	{ translationKey: "skills.core_skills.nextjs", mastery: 90, icon: "simple-icons:nextdotjs" },
	{ translationKey: "skills.core_skills.tailwindcss", mastery: 95, icon: "simple-icons:tailwindcss" },
]

const secondarySkills: Skill[] = [
	{ translationKey: "skills.secondary_skills.nodejs", mastery: 85, icon: "simple-icons:nodedotjs" },
	{ translationKey: "skills.secondary_skills.express", mastery: 85, icon: "simple-icons:express" },
	{ translationKey: "skills.secondary_skills.prisma", mastery: 90, icon: "simple-icons:prisma" },
	{ translationKey: "skills.secondary_skills.postgresql", mastery: 88, icon: "simple-icons:postgresql" },
	{ translationKey: "skills.secondary_skills.zustand", mastery: 85, icon: "mdi:hexagon-multiple-outline" },
	{ translationKey: "skills.secondary_skills.signals", mastery: 85, icon: "mdi:sine-wave" },
	{ translationKey: "skills.secondary_skills.reactnative", mastery: 80, icon: "simple-icons:react" },
	{ translationKey: "skills.secondary_skills.expo", mastery: 80, icon: "simple-icons:expo" },
	{ translationKey: "skills.secondary_skills.socketio", mastery: 85, icon: "simple-icons:socketdotio" },
	{ translationKey: "skills.secondary_skills.electron", mastery: 85, icon: "simple-icons:electron" },
]

const additionalSkills: Skill[] = [
	{ translationKey: "skills.additional_skills.docker", mastery: 85, icon: "simple-icons:docker" },
	{ translationKey: "skills.additional_skills.linux", mastery: 80, icon: "simple-icons:linux" },
	{ translationKey: "skills.additional_skills.aws", mastery: 78, icon: "simple-icons:amazonaws" },
	{ translationKey: "skills.additional_skills.github", mastery: 95, icon: "simple-icons:github" },
	{ translationKey: "skills.additional_skills.gitlab", mastery: 90, icon: "simple-icons:gitlab" },
	{ translationKey: "skills.additional_skills.figma", mastery: 95, icon: "simple-icons:figma" },
	{ translationKey: "skills.additional_skills.design_thinking", mastery: 95, icon: "mdi:lightbulb-on-outline" },
	{ translationKey: "skills.additional_skills.problem_solving", mastery: 95, icon: "mdi:brain" },
	{ translationKey: "skills.additional_skills.agile", mastery: 95, icon: "mdi:account-group-outline" },
	{ translationKey: "skills.additional_skills.empathy", mastery: 90, icon: "mdi:heart-outline" },
	{ translationKey: "skills.additional_skills.tenacity", mastery: 95, icon: "mdi:arm-flex-outline" },
	{ translationKey: "skills.additional_skills.python", mastery: 35, icon: "simple-icons:python" },
]
---

<section
	class="skills-orbital-section relative flex min-h-screen items-center overflow-hidden py-24"
	id="skills"
>
	<div class="skills-decor pointer-events-none absolute inset-0 overflow-hidden" aria-hidden="true">
		<svg class="skills-shape skills-shape--primary absolute -right-40 top-16 h-[680px] w-[680px] opacity-[0.055]" viewBox="0 0 680 680" fill="none">
			<circle cx="340" cy="340" r="300" stroke="#f0e6d2" stroke-width="0.8"></circle>
			<circle cx="340" cy="340" r="210" stroke="#3a7a4d" stroke-width="0.6"></circle>
			<path d="M120 340H560M340 120V560" stroke="#f0e6d2" stroke-width="0.45"></path>
		</svg>
		<svg class="skills-shape absolute -left-24 bottom-8 h-[420px] w-[420px] opacity-[0.04]" viewBox="0 0 420 420" fill="none">
			<circle cx="210" cy="210" r="188" stroke="#f0e6d2" stroke-width="0.7"></circle>
			<path d="M72 274L150 108L318 132L348 306L182 352Z" stroke="#3a7a4d" stroke-width="0.7" stroke-linejoin="round"></path>
		</svg>
	</div>

	<div class="relative z-10 mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
		<div class="mb-16 text-center">
			<h2
				class="skills-orbital-heading mb-4 text-4xl font-bold md:text-5xl"
				style="color: #f0e6d2;"
				data-i18n="skills.title"
			>
				{t("skills.title")}
			</h2>
			<p class="skills-orbital-subtitle max-w-lg mx-auto text-base" style="color: #a89a84;" data-i18n="skills.subtitle">
				{t("skills.subtitle")}
			</p>
		</div>

		<div class="skills-orbital-container relative mx-auto flex items-center justify-center" style="height: 640px; max-width: 640px;">
			{/* Center label */}
			<div
				class="skills-orbital-center absolute z-20 flex flex-col items-center justify-center rounded-full border"
				style="width: 120px; height: 120px; background-color: rgba(20, 26, 20, 0.8); border-color: rgba(58, 122, 77, 0.3);"
			>
				<span class="text-xs font-medium" style="color: #a89a84;" data-i18n="skills.mastery">{t("skills.mastery")}</span>
				<span class="text-lg font-bold" style="color: #f0e6d2;">Stack</span>
			</div>

			{/* Inner ring — Core skills */}
			<div
				class="skills-orbital-ring skills-orbital-ring--inner absolute rounded-full border"
				style="width: 240px; height: 240px; border-color: rgba(58, 122, 77, 0.12);"
			>
				{
					coreSkills.map((skill, index) => {
						// eslint-disable-next-line @typescript-eslint/no-explicit-any
						const skillName = t(skill.translationKey as any)
						const angle = (360 / coreSkills.length) * index
						const radius = 120
						const x = Math.cos((angle * Math.PI) / 180) * radius
						const y = Math.sin((angle * Math.PI) / 180) * radius

						return (
							<div
								class="skill-orbital-item absolute flex flex-col items-center justify-center rounded-full border"
								style={`width: 58px; height: 58px; left: calc(50% + ${x}px - 29px); top: calc(50% + ${y}px - 29px); background-color: rgba(20, 26, 20, 0.9); border-color: rgba(58, 122, 77, 0.25);`}
								data-skill-name={skillName}
								data-i18n-data-skill-name={skill.translationKey}
							>
								<Icon
									name={skill.icon}
									class="h-6 w-6"
									aria-label={skillName}
									data-i18n-aria-label={skill.translationKey}
									style="color: #f0e6d2;"
								/>
							</div>
						)
					})
				}
			</div>

			{/* Middle ring — Secondary skills */}
			<div
				class="skills-orbital-ring skills-orbital-ring--middle absolute rounded-full border"
				style="width: 400px; height: 400px; border-color: rgba(58, 122, 77, 0.1);"
			>
				{
					secondarySkills.map((skill, index) => {
						// eslint-disable-next-line @typescript-eslint/no-explicit-any
						const skillName = t(skill.translationKey as any)
						const angle = (360 / secondarySkills.length) * index
						const radius = 200
						const x = Math.cos((angle * Math.PI) / 180) * radius
						const y = Math.sin((angle * Math.PI) / 180) * radius

						return (
							<div
								class="skill-orbital-item absolute flex flex-col items-center justify-center rounded-full border"
								style={`width: 52px; height: 52px; left: calc(50% + ${x}px - 26px); top: calc(50% + ${y}px - 26px); background-color: rgba(20, 26, 20, 0.9); border-color: rgba(58, 122, 77, 0.2);`}
								data-skill-name={skillName}
								data-i18n-data-skill-name={skill.translationKey}
							>
								<Icon
									name={skill.icon}
									class="h-5 w-5"
									aria-label={skillName}
									data-i18n-aria-label={skill.translationKey}
									style="color: #f0e6d2;"
								/>
							</div>
						)
					})
				}
			</div>

			{/* Outer ring — Additional skills */}
			<div
				class="skills-orbital-ring skills-orbital-ring--outer absolute rounded-full border"
				style="width: 560px; height: 560px; border-color: rgba(58, 122, 77, 0.08);"
			>
				{
					additionalSkills.map((skill, index) => {
						// eslint-disable-next-line @typescript-eslint/no-explicit-any
						const skillName = t(skill.translationKey as any)
						const angle = (360 / additionalSkills.length) * index
						const radius = 280
						const x = Math.cos((angle * Math.PI) / 180) * radius
						const y = Math.sin((angle * Math.PI) / 180) * radius

						return (
							<div
								class="skill-orbital-item absolute flex flex-col items-center justify-center rounded-full border"
								style={`width: 44px; height: 44px; left: calc(50% + ${x}px - 22px); top: calc(50% + ${y}px - 22px); background-color: rgba(20, 26, 20, 0.9); border-color: rgba(58, 122, 77, 0.15);`}
								data-skill-name={skillName}
								data-i18n-data-skill-name={skill.translationKey}
							>
								<Icon
									name={skill.icon}
									class="h-4 w-4"
									aria-label={skillName}
									data-i18n-aria-label={skill.translationKey}
									style="color: #f0e6d2;"
								/>
							</div>
						)
					})
				}
			</div>

			<div class="skills-ring-label skills-ring-label--core" data-i18n="skills.core">
				{t("skills.core")}
			</div>
			<div class="skills-ring-label skills-ring-label--systems" data-i18n="skills.systems">
				{t("skills.systems")}
			</div>
			<div class="skills-ring-label skills-ring-label--craft" data-i18n="skills.craft">
				{t("skills.craft")}
			</div>
		</div>
	</div>
</section>

<style>
	.skills-orbital-ring--inner {
		animation: orbit-clockwise 60s linear infinite;
	}

	.skills-orbital-ring--middle {
		animation: orbit-counterclockwise 80s linear infinite;
	}

	.skills-orbital-ring--outer {
		animation: orbit-clockwise 100s linear infinite;
	}

	.skills-orbital-container:hover .skills-orbital-ring {
		animation-play-state: paused;
	}

	.skills-orbital-container:hover .skill-orbital-item {
		animation-play-state: paused;
	}

	.skills-ring-label {
		position: absolute;
		z-index: 18;
		pointer-events: none;
		font-family: var(--font-mono);
		font-size: 9px;
		letter-spacing: 0.22em;
		text-transform: uppercase;
		color: #6b6055;
	}

	.skills-ring-label--core {
		top: calc(50% - 154px);
		left: 50%;
		transform: translateX(-50%);
	}

	.skills-ring-label--systems {
		top: calc(50% + 218px);
		left: calc(50% - 150px);
	}

	.skills-ring-label--craft {
		top: calc(50% - 300px);
		right: calc(50% - 280px);
	}

	/* Counter-rotate items so icons stay upright */
	.skills-orbital-ring--inner .skill-orbital-item {
		animation: counter-rotate-clockwise 60s linear infinite;
	}

	.skills-orbital-ring--middle .skill-orbital-item {
		animation: counter-rotate-counterclockwise 80s linear infinite;
	}

	.skills-orbital-ring--outer .skill-orbital-item {
		animation: counter-rotate-clockwise 100s linear infinite;
	}

	@keyframes orbit-clockwise {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	@keyframes orbit-counterclockwise {
		from { transform: rotate(360deg); }
		to { transform: rotate(0deg); }
	}

	@keyframes counter-rotate-clockwise {
		from { transform: rotate(0deg); }
		to { transform: rotate(-360deg); }
	}

	@keyframes counter-rotate-counterclockwise {
		from { transform: rotate(0deg); }
		to { transform: rotate(360deg); }
	}

	/* Tooltip on hover */
	.skill-orbital-item::after {
		content: attr(data-skill-name);
		position: absolute;
		bottom: calc(100% + 8px);
		left: 50%;
		transform: translateX(-50%);
		padding: 4px 8px;
		border-radius: 6px;
		font-size: 11px;
		font-weight: 500;
		white-space: nowrap;
		pointer-events: none;
		opacity: 0;
		transition: opacity 0.2s ease;
		background-color: rgba(20, 26, 20, 0.95);
		color: #f0e6d2;
		border: 1px solid rgba(58, 122, 77, 0.3);
	}

	.skill-orbital-item:hover::after {
		opacity: 1;
	}

	.skill-orbital-item:hover {
		border-color: rgba(58, 122, 77, 0.5);
		box-shadow: 0 0 20px rgba(58, 122, 77, 0.2);
		transform: scale(1.15);
		transition: all 0.3s ease;
	}

	.skill-orbital-item svg {
		color: #f0e6d2;
	}
</style>

<script>
	import gsap from "gsap"
	import ScrollTrigger from "gsap/ScrollTrigger"
	import DrawSVGPlugin from "gsap/DrawSVGPlugin"
	import { splitTextReveal } from "@/lib/animations"

	gsap.registerPlugin(ScrollTrigger, DrawSVGPlugin)

	let orbitalCtx: gsap.Context | null = null
	let decorDrawn = false

	function initSkillsOrbitalAnimations() {
		if (orbitalCtx) {
			orbitalCtx.revert()
		}

		orbitalCtx = gsap.context(() => {
			const section = document.querySelector("#skills")
			if (!section) return

			const heading = section.querySelector(".skills-orbital-heading")
			const subtitle = section.querySelector(".skills-orbital-subtitle")
			const rings = section.querySelectorAll(".skills-orbital-ring")
			const items = section.querySelectorAll(".skill-orbital-item")
			const center = section.querySelector(".skills-orbital-center")
			const shapes = section.querySelectorAll(".skills-shape circle, .skills-shape path")

			// Heading SplitText reveal
			if (heading) {
				splitTextReveal(heading, { type: "lines", mask: true })
			}

			// Subtitle fade in after heading
			if (subtitle) {
				gsap.fromTo(
					subtitle,
					{ opacity: 0, y: 20 },
					{
						opacity: 1,
						y: 0,
						duration: 0.6,
						delay: 0.4,
						ease: "power2.out",
						scrollTrigger: {
							trigger: subtitle,
							start: "top 85%",
							toggleActions: "play none none none",
						},
					}
				)
			}

			// GSAP entrance: rings scale from 0 to 1
			gsap.fromTo(
				rings,
				{ scale: 0, opacity: 0 },
				{
					scale: 1,
					opacity: 1,
					duration: 1,
					stagger: 0.2,
					ease: "back.out(1.2)",
					scrollTrigger: {
						trigger: section.querySelector(".skills-orbital-container"),
						start: "top 80%",
						toggleActions: "play none none none",
					},
				}
			)

			// Center label entrance
			if (center) {
				gsap.fromTo(
					center,
					{ scale: 0, opacity: 0 },
					{
						scale: 1,
						opacity: 1,
						duration: 0.8,
						ease: "back.out(1.5)",
						scrollTrigger: {
							trigger: section.querySelector(".skills-orbital-container"),
							start: "top 80%",
							toggleActions: "play none none none",
						},
					}
				)
			}

			// Items scale from 0 to 1 with back.out
			gsap.fromTo(
				items,
				{ scale: 0, opacity: 0 },
				{
					scale: 1,
					opacity: 1,
					duration: 0.6,
					stagger: 0.04,
					ease: "back.out(1.7)",
					scrollTrigger: {
						trigger: section.querySelector(".skills-orbital-container"),
						start: "top 75%",
						toggleActions: "play none none none",
					},
				}
			)

			if (!decorDrawn && shapes.length) {
				decorDrawn = true
				gsap.fromTo(
					shapes,
					{ drawSVG: "0% 0%" },
					{
						drawSVG: "0% 100%",
						duration: 1.1,
						stagger: 0.08,
						ease: "power2.out",
						scrollTrigger: {
							trigger: section,
							start: "top 82%",
							toggleActions: "play none none none",
							once: true,
						},
					}
				)
			}
		}, "#skills")
	}

	initSkillsOrbitalAnimations()
	document.addEventListener("astro:after-swap", () => {
		initSkillsOrbitalAnimations()
	})
</script>
