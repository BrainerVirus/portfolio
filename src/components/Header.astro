---
import { getLangFromUrl, getTranslations } from "@/i18n/utils"
import LanguageSwitch from "./LanguageSwitch.astro"

const lang = getLangFromUrl(Astro.url)
const t = getTranslations(lang)
---

<header class="glass-card fixed top-0 left-0 z-50 w-full">
	<div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6">
		<div class="flex items-center gap-4">
			<div class="relative flex h-10 w-10 items-center justify-center">
				<div class="logo-ring absolute inset-0 animate-pulse rounded-full"></div>
				<div class="cup-glow relative flex items-center justify-center">
					<span
						class="material-symbols-outlined scale-x-[-1] text-xl"
						style="color: #0f0514; -webkit-text-stroke: 1.5px oklch(49.6% 0.272 303.89)"
						>local_cafe</span
					>
				</div>
			</div>
			<div class="hidden flex-col items-start leading-none sm:flex">
				<h1
					class="font-display bg-linear-to-r from-white to-gray-400 bg-clip-text text-xl font-bold tracking-widest text-transparent uppercase"
				>
					Cristhofer Pincetti
				</h1>
				<span class="text-primary/80 mt-1 font-mono text-[10px] tracking-[0.3em] uppercase"
					>Software Engineer</span
				>
			</div>
		</div>
		<nav class="hidden items-center gap-8 md:flex">
			<a class="text-sm font-medium text-gray-300 hover:text-white" href="#about">
				{t("nav.about")}
			</a>
			<a class="text-sm font-medium text-gray-300 hover:text-white" href="#experience">
				{t("nav.experience")}
			</a>
			<a class="text-sm font-medium text-gray-300 hover:text-white" href="#skills">
				{t("nav.skills")}
			</a>
			<a class="text-sm font-medium text-gray-300 transition-colors hover:text-white" href="#contact">
				{t("nav.contact")}
			</a>
			<LanguageSwitch />
		</nav>
		<div class="flex items-center gap-4 md:hidden">
			<LanguageSwitch />
			<button id="mobile-menu-btn" class="text-white" aria-label="Open menu">
				<span class="material-symbols-outlined">menu</span>
			</button>
		</div>
	</div>
	<!-- Mobile menu -->
	<div
		id="mobile-menu"
		class="bg-background-dark/95 hidden border-t border-white/10 backdrop-blur-lg md:hidden"
	>
		<nav class="flex flex-col gap-4 px-6 py-4">
			<a class="text-sm font-medium text-gray-300 transition-colors hover:text-white" href="#about">
				{t("nav.about")}
			</a>
			<a
				class="text-sm font-medium text-gray-300 transition-colors hover:text-white"
				href="#experience"
			>
				{t("nav.experience")}
			</a>
			<a
				class="text-sm font-medium text-gray-300 transition-colors hover:text-white"
				href="#skills"
			>
				{t("nav.skills")}
			</a>
			<a class="text-sm font-medium text-gray-300 transition-colors hover:text-white" href="#contact">
				{t("nav.contact")}
			</a>
		</nav>
	</div>
</header>

<script>
	import gsap from "gsap"
	import { ScrollTrigger } from "gsap/ScrollTrigger"
	gsap.registerPlugin(ScrollTrigger)

	// Mobile menu toggle
	function initMobileMenu() {
		const menuBtn = document.getElementById("mobile-menu-btn")
		const mobileMenu = document.getElementById("mobile-menu")
		const menuIcon = menuBtn?.querySelector(".material-symbols-outlined")

		if (!menuBtn || !mobileMenu || !menuIcon) return

		const toggleMenu = () => {
			const isOpen = mobileMenu.classList.contains("hidden")
			if (isOpen) {
				mobileMenu.classList.add("hidden")
				menuBtn.setAttribute("aria-expanded", "false")
				menuIcon.textContent = "menu"
			} else {
				mobileMenu.classList.remove("hidden")
				menuBtn.setAttribute("aria-expanded", "true")
				menuIcon.textContent = "close"
			}
		}

		menuBtn.addEventListener("click", toggleMenu)

		// Close menu when clicking nav links
		const mobileLinks = mobileMenu.querySelectorAll("a")
		mobileLinks.forEach((link) => {
			link.addEventListener("click", () => {
				mobileMenu.classList.add("hidden")
				menuBtn.setAttribute("aria-expanded", "false")
				menuIcon.textContent = "menu"
			})
		})
	}

	// Scroll-spy with elastic morphing underline
	let scrollObserver: IntersectionObserver | null = null

	function initNavScrollSpy() {
		// Disconnect previous observer
		if (scrollObserver) {
			scrollObserver.disconnect()
			scrollObserver = null
		}

		const navLinks = document.querySelectorAll("header nav a")
		const sections = ["about", "experience", "skills", "contact"]
			.map((id) => document.getElementById(id))
			.filter(Boolean)

		if (!navLinks.length || !sections.length) return

		let underline = document.querySelector("#nav-underline") as HTMLElement | null
		if (!underline) {
			underline = document.createElement("div")
			underline.id = "nav-underline"
			underline.className = "absolute bottom-0 left-0 h-0.5 rounded-full bg-primary"
			underline.style.transition = "none"
			const nav = document.querySelector("header nav") as HTMLElement | null
			if (nav) {
				nav.style.position = "relative"
				nav.appendChild(underline)
			}
		}

		const linkToSection: Record<string, string> = {}
		navLinks.forEach((link) => {
			const href = link.getAttribute("href") || ""
			const id = href.replace("/", "").replace("#", "")
			if (id) {
				linkToSection[id] = id
				;(link as HTMLElement).dataset.section = id
			}
		})

		function updateActiveLink(activeId: string) {
			navLinks.forEach((link) => {
				const sectionId = (link as HTMLElement).dataset.section
				if (sectionId === activeId) {
					link.classList.add("text-white")
					link.classList.remove("text-gray-300")
					const rect = link.getBoundingClientRect()
					const navRect = link.closest("nav")?.getBoundingClientRect()
					if (navRect && underline) {
						gsap.to(underline, {
							left: rect.left - navRect.left,
							width: rect.width,
							duration: 0.5,
							ease: "elastic.out(1, 0.6)",
						})
					}
				} else {
					link.classList.add("text-gray-300")
					link.classList.remove("text-white")
				}
			})
		}

		scrollObserver = new IntersectionObserver(
			(entries) => {
				entries.forEach((entry) => {
					if (entry.isIntersecting) {
						const id = entry.target.id
						updateActiveLink(id)
					}
				})
			},
			{
				rootMargin: "-20% 0px -60% 0px",
				threshold: 0,
			}
		)

		sections.forEach((section) => {
			if (section) scrollObserver!.observe(section)
		})

		const hash = window.location.hash.replace("#", "")
		if (hash && linkToSection[hash]) {
			updateActiveLink(hash)
		}

		navLinks.forEach((link) => {
			link.addEventListener("click", () => {
				const sectionId = (link as HTMLElement).dataset.section
				if (sectionId) {
					updateActiveLink(sectionId)
				}
			})
		})
	}

	initMobileMenu()
	initNavScrollSpy()
	document.addEventListener("astro:after-swap", () => {
		initMobileMenu()
		initNavScrollSpy()
	})
</script>
