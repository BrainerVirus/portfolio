---
import { getLangFromUrl, getTranslations } from "@/i18n/utils"
import LanguageSwitch from "./LanguageSwitch.astro"

const lang = getLangFromUrl(Astro.url)
const t = getTranslations(lang)
---

<header class="glass-card fixed top-0 left-0 z-50 w-full">
	<div class="mx-auto flex h-20 max-w-7xl items-center justify-between px-6">
		<div class="flex items-center gap-4">
			<div class="relative flex h-10 w-10 items-center justify-center">
				<div class="logo-ring absolute inset-0 animate-pulse rounded-full"></div>
				<div class="cup-glow relative flex items-center justify-center">
					<span
						class="material-symbols-outlined scale-x-[-1] text-xl"
						style="color: #0f0514; -webkit-text-stroke: 1.5px oklch(49.6% 0.272 303.89)"
						>local_cafe</span
					>
				</div>
			</div>
			<div class="hidden flex-col items-start leading-none sm:flex">
				<h1
					class="font-display bg-linear-to-r from-white to-gray-400 bg-clip-text text-xl font-bold tracking-widest text-transparent uppercase"
				>
					Cristhofer Pincetti
				</h1>
				<span class="text-primary/80 mt-1 font-mono text-[10px] tracking-[0.3em] uppercase"
					>Software Engineer</span
				>
			</div>
		</div>
		<nav class="hidden items-center gap-8 md:flex">
			<a class="text-sm font-medium text-gray-300 hover:text-white" href="#about">
				{t("nav.about")}
			</a>
			<a class="text-sm font-medium text-gray-300 hover:text-white" href="#experience">
				{t("nav.experience")}
			</a>
			<a class="text-sm font-medium text-gray-300 hover:text-white" href="#skills">
				{t("nav.skills")}
			</a>
			<a class="text-sm font-medium text-gray-300 transition-colors hover:text-white" href="#contact">
				{t("nav.contact")}
			</a>
			<LanguageSwitch />
		</nav>
		<div class="flex items-center gap-4 md:hidden">
			<LanguageSwitch />
			<button id="mobile-menu-btn" class="text-white" aria-label="Open menu">
				<span class="material-symbols-outlined">menu</span>
			</button>
		</div>
	</div>
	<!-- Mobile menu -->
	<div
		id="mobile-menu"
		class="bg-background-dark/95 hidden border-t border-white/10 backdrop-blur-lg md:hidden"
	>
		<nav class="flex flex-col gap-4 px-6 py-4">
			<a class="text-sm font-medium text-gray-300 transition-colors hover:text-white" href="#about">
				{t("nav.about")}
			</a>
			<a
				class="text-sm font-medium text-gray-300 transition-colors hover:text-white"
				href="#experience"
			>
				{t("nav.experience")}
			</a>
			<a
				class="text-sm font-medium text-gray-300 transition-colors hover:text-white"
				href="#skills"
			>
				{t("nav.skills")}
			</a>
			<a class="text-sm font-medium text-gray-300 transition-colors hover:text-white" href="#contact">
				{t("nav.contact")}
			</a>
		</nav>
	</div>
</header>

<script>
	import gsap from "gsap"
	import { ScrollTrigger } from "gsap/ScrollTrigger"
	gsap.registerPlugin(ScrollTrigger)

	// Mobile menu toggle
	function initMobileMenu() {
		const menuBtn = document.getElementById("mobile-menu-btn")
		const mobileMenu = document.getElementById("mobile-menu")
		const menuIcon = menuBtn?.querySelector(".material-symbols-outlined")

		if (!menuBtn || !mobileMenu || !menuIcon) return

		const toggleMenu = () => {
			const isHidden = mobileMenu.classList.contains("hidden")
			if (isHidden) {
				mobileMenu.classList.remove("hidden")
				menuBtn.setAttribute("aria-expanded", "true")
				menuIcon.textContent = "close"
			} else {
				mobileMenu.classList.add("hidden")
				menuBtn.setAttribute("aria-expanded", "false")
				menuIcon.textContent = "menu"
			}
		}

		menuBtn.addEventListener("click", toggleMenu)

		// Close menu when clicking nav links
		const mobileLinks = mobileMenu.querySelectorAll("a")
		mobileLinks.forEach((link) => {
			link.addEventListener("click", () => {
				mobileMenu.classList.add("hidden")
				menuBtn.setAttribute("aria-expanded", "false")
				menuIcon.textContent = "menu"
			})
		})
	}

	// Scroll-spy with elastic morphing underline
	let scrollObserver: IntersectionObserver | null = null

	function initNavScrollSpy() {
		if (scrollObserver) {
			scrollObserver.disconnect()
			scrollObserver = null
		}

		const nav = document.querySelector("header nav") as HTMLElement | null
		const navLinks = document.querySelectorAll("header nav a")
		const sections = ["about", "experience", "skills", "contact"]
			.map((id) => document.getElementById(id))
			.filter(Boolean)

		if (!navLinks.length || !sections.length || !nav) return

		// Create underline element if not exists
		let underline = document.querySelector("#nav-underline") as HTMLElement | null
		if (!underline) {
			underline = document.createElement("div")
			underline.id = "nav-underline"
			underline.className = "absolute bottom-0 h-0.5 rounded-full bg-primary"
			underline.style.transition = "none"
			underline.style.pointerEvents = "none"
			nav.style.position = "relative"
			nav.appendChild(underline)
		}

		// Remove old active states
		navLinks.forEach((link) => {
			link.classList.add("text-gray-300")
			link.classList.remove("text-white")
		})

		function moveToLink(link: Element) {
			const linkRect = link.getBoundingClientRect()
			const navRect = nav!.getBoundingClientRect()
			const left = linkRect.left - navRect.left
			const width = linkRect.width

			gsap.to(underline, {
				left,
				width,
				duration: 0.7,
				ease: "elastic.out(1, 0.65)",
				overwrite: "auto",
			})

			// Highlight active link
			navLinks.forEach((l) => {
				l.classList.add("text-gray-300")
				l.classList.remove("text-white")
			})
			link.classList.add("text-white")
			link.classList.remove("text-gray-300")
		}

		scrollObserver = new IntersectionObserver(
			(entries) => {
				// Find the entry with highest intersection ratio
				const visible = entries
					.filter((e) => e.isIntersecting)
					.sort((a, b) => b.intersectionRatio - a.intersectionRatio)[0]

				if (visible) {
					const link = document.querySelector(`header nav a[href="#${visible.target.id}"]`)
					if (link) moveToLink(link)
				}
			},
			{ rootMargin: "-30% 0px -70% 0px", threshold: [0, 0.25, 0.5, 0.75, 1] }
		)

		sections.forEach((section) => {
			if (section) scrollObserver!.observe(section)
		})

		// Set initial active based on hash
		const hash = window.location.hash.replace("#", "")
		if (hash) {
			const link = document.querySelector(`header nav a[href="#${hash}"]`)
			if (link) moveToLink(link)
		}

		// Click handlers
		navLinks.forEach((link) => {
			link.addEventListener("click", () => moveToLink(link))
		})
	}

	initMobileMenu()
	initNavScrollSpy()
	document.addEventListener("astro:after-swap", () => {
		initMobileMenu()
		initNavScrollSpy()
	})
</script>
