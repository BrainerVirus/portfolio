---
import { getLangFromUrl, type Language } from "@/i18n/utils"

const lang = getLangFromUrl(Astro.url)
const otherLang: Language = lang === "en" ? "es" : "en"

const pathname = Astro.url.pathname
const segments = pathname.split("/").filter(Boolean)
if (segments[0] === "en" || segments[0] === "es") {
	segments.shift()
}
const targetPath = `/${otherLang}${segments.length ? "/" + segments.join("/") : "/"}`

const tooltip = lang === "en" ? "Español" : "English"
---

<button
	id="lang-switch"
	class="group relative flex h-10 w-10 cursor-pointer items-center justify-center rounded-full border border-white/10 bg-white/5 transition-colors hover:bg-white/10 hover:border-white/20"
	data-target-lang={otherLang}
	data-target-path={targetPath}
	aria-label={tooltip}
>
	<span
		id="lang-icon"
		class="material-symbols-outlined inline-block text-gray-300 text-xl transition-colors group-hover:text-white"
	>
		language
	</span>
	<!-- Language indicator dot -->
	<span
		class={`absolute -right-0.5 -bottom-0.5 h-2 w-2 rounded-full border border-white/10 ${lang === "en" ? "bg-blue-400" : "bg-amber-400"}`}
	>
	</span>
	<!-- Tooltip -->
	<span class="pointer-events-none absolute -top-8 left-1/2 -translate-x-1/2 whitespace-nowrap rounded-md bg-white/10 px-2 py-1 text-xs text-gray-300 opacity-0 transition-opacity duration-200 group-hover:opacity-100">
		{tooltip}
	</span>
</button>

<script>
	import gsap from "gsap"
	import { navigate } from "astro:transitions/client"

	function initLangSwitch() {
		const btn = document.querySelector("#lang-switch")
		const icon = document.querySelector("#lang-icon")
		if (!btn || !icon) return

		btn.addEventListener("click", () => {
			const targetPath = btn.getAttribute("data-target-path")
			const targetLang = btn.getAttribute("data-target-lang")

			document.cookie = `lang=${targetLang}; path=/; max-age=31536000; SameSite=Lax`

			gsap.to(icon, {
				rotation: 360,
				duration: 0.6,
				ease: "elastic.out(1, 0.5)",
				onComplete: () => {
					navigate(targetPath || "/")
				},
			})
		})
	}

	initLangSwitch()
	document.addEventListener("astro:after-swap", initLangSwitch)
</script>
