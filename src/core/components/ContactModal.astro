---
import Typography from "@core/components/Typography.astro"
import { getLangFromUrl, useTranslations } from "@core/i18n/utils"
import { actions, isInputError } from "astro:actions"
const { modalId } = Astro.props

const lang = getLangFromUrl(Astro.url)
const t = useTranslations(lang)

const result = Astro.getActionResult(actions.sendEmail)
const inputErrors = isInputError(result?.error) ? result.error.fields : {}
---

<dialog id={modalId} class="modal" data-modal-id={modalId}>
	<div class="modal-box">
		<Typography as="h4" variant="h4" color="inherit" fontWeight="semibold">
			{t("contactModal.title")}</Typography
		>
		<div class="modal-action">
			<form method="dialog">
				<button class="btn btn-circle btn-ghost btn-sm absolute top-2 right-2">✕</button>
			</form>
			<form
				class="flex w-full flex-col gap-6"
				aria-label="Contact form"
				method="POST"
				action={actions.sendEmail}
			>
				<label class="form-control items-start gap-2" for="name">
					<span class="label-text">{t("contactModal.name")}</span>
					<input class="input input-bordered w-full" type="text" id="name" name="name" />
				</label>
				<div>{inputErrors.name}</div>

				<label class="form-control items-start gap-2" for="email">
					<span class="label-text">{t("contactModal.email")}</span>
					<input class="input input-bordered w-full" type="email" id="email" name="email" />
				</label>
				<div>{inputErrors.email}</div>

				<label class="form-control items-start gap-2" for="message">
					<span class="label-text">{t("contactModal.message")}</span>
					<textarea class="textarea textarea-bordered w-full" id="message" name="message"
					></textarea>
				</label>

				<button class="btn btn-primary btn-md mt-1">{t("contactModal.submit")}</button>
			</form>
		</div>
	</div>
</dialog>

