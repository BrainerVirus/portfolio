{
  "name": "@brainervirus.dev/personal-portfolio",
  "type": "module",
  "version": "3.0.0",
  "private": false,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "commit": "git-cz",
    "check": "astro check && tsc --noEmit",
    "lint": "eslint",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write 'src/**/*.{astro,ts,js,tsx,jsx,css}'",
    "format:check": "prettier --check 'src/**/*.{astro,ts,js,tsx,jsx,css}'",
    "semantic-release": "semantic-release",
    "test:unit": "vitest",
    "test:e2e": "pnpm exec playwright test",
    "test": "pnpm test:unit && pnpm test:e2e",
    "prepare": "husky"
  },
  "dependencies": {
    "@astrojs/check": "0.9.6",
    "@astrojs/mdx": "4.3.13",
    "@astrojs/vercel": "9.0.4",
    "@midudev/tailwind-animations": "1.0.1",
    "@tailwindcss/vite": "4.1.18",
    "astro": "6.1.6",
    "astro-icon": "1.1.5",
    "resend": "6.7.0",
    "tailwindcss": "4.1.18",
    "typescript": "5.9.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@iconify-json/cib": "1.2.3",
    "@iconify-json/devicon": "^1.2.57",
    "@iconify-json/fa6-brands": "1.2.6",
    "@iconify-json/grommet-icons": "1.2.4",
    "@iconify-json/mdi": "1.2.3",
    "@iconify-json/simple-icons": "1.2.66",
    "@playwright/test": "1.57.0",
    "@tailwindcss/typography": "0.5.19",
    "@typescript-eslint/parser": "8.53.0",
    "astro-eslint-parser": "1.2.2",
    "clsx": "2.1.1",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "eslint": "9.39.2",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-astro": "1.5.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-prettier": "5.5.5",
    "globals": "17.0.0",
    "happy-dom": "15.11.1",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.8.0",
    "prettier-plugin-astro": "0.14.1",
    "prettier-plugin-astro-organize-imports": "0.4.11",
    "prettier-plugin-tailwindcss": "0.7.2",
    "tailwind-merge": "3.4.0",
    "tw-animate-css": "1.4.0",
    "typescript-eslint": "8.53.0",
    "vitest": "4.0.18",
    "@vitest/ui": "4.0.18"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BrainerVirus/portfolio.git"
  }
}
