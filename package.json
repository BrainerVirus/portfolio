{
  "name": "@brainervirus.dev/personal-portfolio",
  "type": "module",
  "version": "3.0.0",
  "packageManager": "pnpm@11.0.3",
  "private": false,
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "commit": "git-cz",
    "check": "astro check && tsc --noEmit",
    "lint": "oxlint src --ignore-pattern \"**/*.astro\"",
    "lint:fix": "oxlint --fix src --ignore-pattern \"**/*.astro\"",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "test:unit": "vitest",
    "test:e2e": "pnpm exec playwright test",
    "test": "pnpm test:unit && pnpm test:e2e"
  },
  "dependencies": {
    "@astrojs/check": "0.9.9",
    "@astrojs/mdx": "5.0.4",
    "@astrojs/react": "^5.0.4",
    "@astrojs/vercel": "10.0.6",
    "@base-ui/react": "^1.4.1",
    "@fontsource/jetbrains-mono": "^5.2.8",
    "@tailwindcss/vite": "4.2.4",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "astro": "6.2.1",
    "astro-icon": "1.1.5",
    "class-variance-authority": "^0.7.1",
    "gsap": "^3.15.0",
    "lucide-react": "^1.14.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "resend": "6.12.2",
    "shadcn": "^4.6.0",
    "sonner": "^2.0.7",
    "tailwindcss": "4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "6.0.3"
  },
  "devDependencies": {
    "@iconify-json/cib": "1.2.3",
    "@iconify-json/devicon": "^1.2.62",
    "@iconify-json/fa6-brands": "1.2.6",
    "@iconify-json/grommet-icons": "1.2.4",
    "@iconify-json/mdi": "1.2.3",
    "@iconify-json/simple-icons": "1.2.80",
    "@playwright/test": "1.59.1",
    "@tailwindcss/typography": "0.5.19",
    "@vitest/ui": "4.1.5",
    "clsx": "2.1.1",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "happy-dom": "20.9.0",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tailwindcss": "^0.6.3",
    "tailwind-merge": "3.5.0",
    "vitest": "4.1.5"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/BrainerVirus/portfolio.git"
  }
}
