# Resend API Key (get yours at https://resend.com/api-keys)
# Format: re_xxxxxxxxxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=

# Email address verified on Resend (used as the "from" address)
# Must be a domain you own, verified on Resend
RESEND_EMAIL=

# Recipient email address (where form submissions are sent)
EMAIL_TO=
