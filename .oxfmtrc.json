{
	"$schema": "./node_modules/oxfmt/configuration_schema.json",
	"printWidth": 100,
	"semi": false,
	"singleQuote": false,
	"useTabs": true,
	"tabWidth": 2,
	"trailingComma": "es5",
	"insertFinalNewline": true,
	"ignorePatterns": [
		"node_modules/",
		"dist/",
		".vercel/",
		".astro/",
		".agents/"
	],
	"overrides": [
		{
			"files": ["*.json", "*.md", "*.toml", "*.yml"],
			"options": {
				"useTabs": false
			}
		}
	]
}
